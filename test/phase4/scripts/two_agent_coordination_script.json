[
  {
    "kind": "subscribe",
    "pattern": "agent.message.*.${AGENT_UID}.*"
  },
  {
    "kind": "receive"
  },
  {
    "kind": "publish",
    "topic": "agent.message.${AGENT_UID}.${AGENT_UID}.response",
    "body": {
      "from_uid": ${AGENT_UID},
      "to_uid": ${AGENT_UID},
      "kind": "response",
      "body": {"summary": "received coordination request, completed summary transformation"}
    }
  },
  {
    "kind": "done"
  }
]
