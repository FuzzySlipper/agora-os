[
  {
    "kind": "subscribe",
    "pattern": "agent.message.*.${AGENT_UID}.*"
  },
  {
    "kind": "receive"
  },
  {
    "kind": "publish",
    "topic": "agent.work.result",
    "body": {
      "task_id": "coord-1",
      "status": "ok",
      "summary": "received coordination request via agent.message, completed summary transformation"
    }
  },
  {
    "kind": "done"
  }
]
