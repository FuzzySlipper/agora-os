{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "lib": ["DOM", "ES2022"],
    "strict": false,
    "noEmitOnError": true,
    "outDir": "./dist/build",
    "rootDir": ".",
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts", "shared/**/*.ts", "desktop/**/*.ts"]
}
